# Copy these values into your local environment. Never commit real keys.
FOODMATE_USE_LLM=0
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com
FOODMATE_LLM_MODEL=deepseek-v4-flash

# Optional Baidu Maps integration
BAIDU_MAP_AK=your-baidu-map-ak

# Retrieval pipeline
FOODMATE_PIPELINE_MODE=bge+cross_encoder+business_rerank
FOODMATE_RENTAL_PIPELINE_MODE=bge+cross_encoder+business_rerank
FOODMATE_BGE_MODEL=BAAI/bge-base-zh-v1.5
FOODMATE_RERANKER_MODEL=BAAI/bge-reranker-base
FOODMATE_RECALL_TOP_K=30

# Data paths
FOODMATE_DATA_PATH=data/restaurants_cuhksz_geo.csv
FOODMATE_RENTAL_DATA_PATH=data/rental_listings_cuhksz_geo.csv
